PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=true

# Comma-separated origins allowed to call this API from browsers.
# Use * only if this endpoint is not exposed publicly.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://wallet.example.com

PRICE_CACHE_TTL_MS=45000
PROVIDER_TIMEOUT_MS=8000
PROVIDER_RETRIES=1
RETRY_BACKOFF_MS=250

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

CG_API_KEY=xxxxx
COINCAP_API_KEY=xxxxx
CRYPTOAPIS_KEY=xxxxx
FREECRYPTOAPI_API_KEY=xxxxx